const express = require('express');
const cors = require('cors');
require('dotenv').config();
const { OpenAI } = require('openai');

const app = express();
app.use(express.json());
app.use(cors());

const openai = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
});

// PI Qualification Logic
const statutes = {
  'AL': 3, 'AK': 4, 'AZ': 3, 'AR': 3, 'CA': 2, 'CO': 2, 'CT': 3, 'DE': 3,
  'FL': 4, 'GA': 2, 'HI': 6, 'ID': 3, 'IL': 2, 'IN': 2, 'IA': 2, 'KS': 2,
  'KY': 2, 'LA': 1, 'ME': 6, 'MD': 3, 'MA': 3, 'MI': 3, 'MN': 6, 'MS': 3,
  'MO': 3, 'MT': 3, 'NE': 4, 'NV': 2, 'NH': 3, 'NJ': 2, 'NM': 3, 'NY': 3,
  'NC': 3, 'ND': 6, 'OH': 2, 'OK': 2, 'OR': 3, 'PA': 4, 'RI': 3, 'SC': 3,
  'SD': 3, 'TN': 1, 'TX': 2, 'UT': 4, 'VT': 3, 'VA': 2, 'WA': 3, 'WV': 2,
  'WI': 3, 'WY': 4
};

function calculateScore(data) {
  let score = 0;

  if (data.state && statutes[data.state]) {
    const incidentDate = new Date(data.incidentDate);
    const yearsAgo = (new Date() - incidentDate) / (1000 * 60 * 60 * 24 * 365);
    if (yearsAgo < statutes[data.state]) {
      score += 25;
    }
  }

  if (data.hasInsurance === 'yes' || data.hasInsurance === true) score += 25;
  else if (data.hasInsurance === 'no' || data.hasInsurance === false) score -= 10;

  if (data.hasPoliceReport === 'yes' || data.hasPoliceReport === true) score += 20;

  const severity = data.injurySeverity?.toLowerCase();
  if (severity === 'catastrophic' || severity === 'permanent') score += 20;
  else if (severity === 'fracture' || severity === 'hospitalization') score += 15;
  else if (severity === 'moderate') score += 10;
  else if (severity === 'soft tissue') score += 5;

  if (data.hasMedicalTreatment === 'yes' || data.hasMedicalTreatment === true) score += 10;

  return Math.max(0, Math.min(100, score));
}

function estimateCaseValue(data) {
  let baseValue = 0;

  const severity = data.injurySeverity?.toLowerCase();
  if (severity === 'catastrophic' || severity === 'permanent') baseValue = 200000;
  else if (severity === 'fracture' || severity === 'hospitalization') baseValue = 75000;
  else if (severity === 'moderate') baseValue = 25000;
  else if (severity === 'soft tissue') baseValue = 10000;

  let multiplier = 1;
  if (data.hasInsurance === 'yes' || data.hasInsurance === true) multiplier = 1.5;
  if (data.hasPoliceReport === 'yes' || data.hasPoliceReport === true) multiplier *= 1.2;

  return Math.round(baseValue * multiplier);
}

// Intake form endpoint
app.post('/api/intake', (req, res) => {
  const caseData = req.body;
  const score = calculateScore(caseData);
  const caseValue = estimateCaseValue(caseData);

  res.json({
    score,
    caseValue,
    decision: score >= 70 ? 'ACCEPT' : score >= 50 ? 'REVIEW' : 'REJECT',
    caseId: 'CASE-' + Date.now()
  });
});

// Chat endpoint
app.post('/api/chat', async (req, res) => {
  try {
    const { message, conversationHistory } = req.body;

    const response = await openai.chat.completions.create({
      model: 'gpt-4',
      messages: [
        {
          role: 'system',
          content: `You are a 24/7 AI intake specialist for a Personal Injury law firm. Your job is to qualify leads quickly and professionally. Ask one question at a time. Be warm but efficient.`
        },
        ...conversationHistory,
        { role: 'user', content: message }
      ],
      temperature: 0.7,
      max_tokens: 150,
    });

    res.json({
      reply: response.choices[0].message.content,
      usage: response.usage,
    });
  } catch (error) {
    console.error('OpenAI error:', error);
    res.status(500).json({ error: error.message });
  }
});

// Score endpoint
app.post('/api/score', (req, res) => {
  const { caseData } = req.body;
  const score = calculateScore(caseData);
  const caseValue = estimateCaseValue(caseData);

  res.json({
    score,
    caseValue,
    decision: score >= 70 ? 'ACCEPT' : score >= 50 ? 'REVIEW' : 'REJECT',
  });
});

// Health check
app.get('/api/health', (req, res) => {
  res.json({ status: 'ok', timestamp: new Date().toISOString() });
});

// Version endpoint
app.get('/api/version', (req, res) => {
  res.json({ version: '1.0.0', environment: process.env.NODE_ENV || 'development' });
});

// Serve static files
app.use(express.static('public'));

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log(`✅ Intake Tech running on port ${PORT}`);
});
